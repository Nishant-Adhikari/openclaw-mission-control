# ── Mission Control Dashboard Config ─────────────────────────────────────────

# Port the dashboard serves on (default 3457)
DASHBOARD_PORT=3457

# OpenClaw-native paths
LOG_FILE=/tmp/openclaw/openclaw-2026-03-26.log
SESSIONS_FILE=/root/.openclaw/agents/main/sessions/sessions.json
OPENCLAW_CONFIG=/root/.openclaw/openclaw.json
MEMORY_DIR=/root/.openclaw/workspaces/main/memory

# Optional: HTTP Basic Auth to protect the dashboard
# Leave blank to disable auth (only do this behind Tailscale or a firewall)
DASHBOARD_USER=
DASHBOARD_PASS=
