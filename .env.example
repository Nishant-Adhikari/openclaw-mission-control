# ── Mission Control Dashboard Config ─────────────────────────────────────────

# Port the dashboard serves on (don't clash with your bot — default 3457)
DASHBOARD_PORT=3457

# tmux stable socket path — must match what your bot uses
TMUX_SOCKET=/root/.tmux/sock

# Paths to data files your bot writes (adjust to your setup)
LOG_FILE=/root/flikpick-os/logs/activity.log
SESSIONS_FILE=/root/flikpick-os/memory/sessions.json
TOKENS_FILE=/root/flikpick-os/memory/tokens.json

# Optional: HTTP Basic Auth to protect the dashboard
# Leave blank to disable auth (only do this behind a firewall)
DASHBOARD_USER=
DASHBOARD_PASS=
