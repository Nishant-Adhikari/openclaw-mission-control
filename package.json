{
  "name": "openclaw-mission-control",
  "version": "1.0.0",
  "description": "Real-time dashboard for OpenClaw systems — gateway health, cron, sessions, logs, and system status",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop mission-control",
    "pm2:logs": "pm2 logs mission-control"
  },
  "keywords": ["openclaw", "dashboard", "monitoring", "cron", "systemd"],
  "author": "Nishant Adhikari",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
